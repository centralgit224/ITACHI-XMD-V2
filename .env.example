# 📞 Votre numéro WhatsApp (sans + et sans espace)
# Exemple: 224621963059
OWNER_NUMBER=224621963059

# 👤 Votre nom (propriétaire du bot)
OWNER_NAME=Ibrahima sory sacko

# 🤖 Nom du bot
